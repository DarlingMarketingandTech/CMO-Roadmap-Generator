# Copy to `.env.local` for local development (Next.js loads it automatically).
# Never commit real secrets.

# --- Resend (required for “Send my roadmap” on the results page) ---
# https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Verified sender, e.g. "CMO Roadmap <onboarding@resend.dev>" for Resend trial,
# or "Your Brand <marketing@yourdomain.com>" after domain verification.
RESEND_FROM="CMO Roadmap <onboarding@resend.dev>"

# Optional: replies go to your team inbox
# RESEND_REPLY_TO=you@yourcompany.com

# --- Strategy / booking CTA ---
# Client-visible booking URL (results page + matches email when server has no STRATEGY_BOOKING_URL).
# NEXT_PUBLIC_BOOKING_URL=https://cal.com/your-org/strategy

# Optional server-only override (same URL as public, or a private link never embedded in client JS).
# STRATEGY_BOOKING_URL=https://cal.com/your-org/strategy

# Mailto fallback when no booking URL is set (server email + default mailto href)
STRATEGY_CONTACT_EMAIL=strategy@example.com

# Optional: log full lead payload (includes email) to server console — off by default even in dev
# LEAD_LOG_VERBOSE=1
